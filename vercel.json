{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" },
    { "src": "server.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "source": "/api/(.*)", "destination": "server.ts" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
